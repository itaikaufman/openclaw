FROM ${OPENCLAW_IMAGE:-openclaw:local}

USER root

RUN apt-get update && \
    apt-get install -y python3-pip && \
    pip3 install --break-system-packages \
      "python-docx==1.2.0" \
      "docx2txt==0.9" \
      "pypdf==6.8.0" \
      "openpyxl==3.1.5" \
      "pandas==3.0.1" \
      "python-pptx==1.0.2" \
      "beautifulsoup4==4.14.3" \
      "lxml==6.0.2" && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER node
